# Copy to `.env` in the repo root for local `make run` / `go run` (not loaded automatically — use a tool
# that reads .env or export manually). For Docker, copy `docker/.env.example` → `docker/.env`.

# --- Database (required) ---
DB_USER=your_db_user
DB_PASS=your_db_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_database_name
# DB_SSLMODE defaults appropriately in development/test when unset.
# Staging/production: require | verify-ca | verify-full (production expects verify-full).
# Docker: with baseline + dev overlay, DB_SSLMODE defaults to disable for local API containers.
# Baseline-only Docker (`make docker-up-baseline`) requires DB_SSLMODE explicitly — see docker/.env.example.
DB_SSLMODE=disable

# --- JWT (required) ---
JWT_SECRET=your_super_secret_jwt_key_here

# --- Server ---
PORT=8080
# APP_ENV=development

# --- Logging & HTTP timeouts (optional) ---
# LOG_LEVEL=info
# HTTP_READ_HEADER_TIMEOUT_SEC=5
# HTTP_READ_TIMEOUT_SEC=30
# HTTP_WRITE_TIMEOUT_SEC=30
# HTTP_IDLE_TIMEOUT_SEC=120

# --- OpenAPI / Swagger (optional) ---
# SWAGGER_HOST=localhost:8080
# SWAGGER_ENABLED=true

# --- Versioned SQL migrations (optional; see docs/MIGRATIONS.md) ---
# USE_VERSIONED_MIGRATIONS=false
# MIGRATIONS_DIR=migrations

# --- Redis (optional) ---
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS_ENABLED=false
REDIS_TLS_SERVER_NAME=
REDIS_TLS_CA_CERT=
REDIS_TLS_INSECURE_SKIP_VERIFY=false

# --- Background job queue (optional; see docs/QUEUE.md) ---
# QUEUE_ENABLED=true
# QUEUE_ASYNC_ENABLED=true
# JOB_QUEUE_ENABLED=
# JOB_WORKER_ENABLED=true
# JOB_MAX_ATTEMPTS=
# JOB_RETRY_DELAY_SECONDS=
# QUEUE_WORKERS=2
# QUEUE_POLL_INTERVAL_MS=500
# QUEUE_MAX_ATTEMPTS=5
# QUEUE_INITIAL_BACKOFF_MS=1000
# QUEUE_MAX_BACKOFF_MS=300000
# QUEUE_SHUTDOWN_TIMEOUT_SEC=30
# QUEUE_DEAD_LETTER_MAX_CAP=10000

# --- Login/register JSON (optional; unset = false) ---
# AUTH_RESPONSE_INCLUDE_API_KEY=true
# AUTH_RESPONSE_INCLUDE_USER=true

# --- JWT lifetimes (optional) ---
# JWT_EXPIRATION_DAYS=1
# JWT_ACCESS_TOKEN_MINUTES=15
# JWT_REFRESH_EXPIRATION_HOURS=720

# --- Rate limiting (optional) ---
# RATE_LIMIT_REQUESTS_PER_MINUTE=60
# RATE_LIMIT_BURST_SIZE=10
# When Redis backs rate limiting, behavior if IncrementRateLimit fails (case-insensitive):
#   fail_closed     -> HTTP 503 (rate limiter unavailable)
#   local_fallback  -> per-process in-memory token bucket (same RPM/burst as Redis)
#   fail_open       -> allow the request (development/test only; rejected at config load in staging/production)
# Defaults: unset -> local_fallback in staging/production; fail_open in development/test (local_fallback is safer in dev if you want consistent limits when Redis blips).
# RATE_LIMIT_REDIS_FAILURE_MODE=

# --- HTTP security headers (optional) ---
# SECURITY_HEADERS_ENABLED defaults true when unset (same pattern as queue toggles).
# SECURITY_HEADERS_ENABLED=true
# HSTS_ENABLED=false
# HSTS_MAX_AGE_SECONDS=31536000
# HSTS_INCLUDE_SUBDOMAINS=false

# --- HTTP audit → Postgres (optional) ---
# AUDIT_HTTP_ENABLED=true
# AUDIT_HTTP_MUTATING_ONLY=true

# --- Admin event telemetry (optional) ---
# EVENT_TELEMETRY_RATE_LIMIT_RPM=120
# EVENT_TELEMETRY_BURST_SIZE=30

# --- MFA / TOTP (optional; 32-byte key base64 or hex) ---
# MFA_ENCRYPTION_KEY=
# MFA_CHALLENGE_TTL_MINUTES=5
# MFA_RECOVERY_CODE_COUNT=8
# MFA_TOTP_ISSUER=goapi

# --- Organization webhooks (optional; same encoding as MFA key) ---
# WEBHOOK_ENCRYPTION_KEY=

# --- OAuth (optional; OAUTH_REDIRECT_BASE_URL required when a provider is enabled) ---
# OAUTH_GOOGLE_ENABLED=false
# OAUTH_GITHUB_ENABLED=false
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=
# OAUTH_GITHUB_CLIENT_ID=
# OAUTH_GITHUB_CLIENT_SECRET=
# OAUTH_REDIRECT_BASE_URL=http://localhost:8080
# OAUTH_STATE_TTL_MINUTES=10
# OAUTH_EXCHANGE_TTL_MINUTES=10

# --- Email (optional; defaults depend on APP_ENV) ---
# EMAIL_ENABLED=true
# EMAIL_PROVIDER=log
# EMAIL_FROM=noreply@localhost
# APP_PUBLIC_URL=http://localhost:8080
# EMAIL_VERIFICATION_TTL_HOURS=48
# EMAIL_PASSWORD_RESET_TTL_HOURS=1
# ORG_INVITATION_TTL_HOURS=168
# EMAIL_RESEND_MIN_INTERVAL_SECONDS=60
# RESEND_API_KEY=
# EMAIL_REDIRECT_ALL_TO=

# --- One-time first admin (optional; remove after bootstrap) ---
# BOOTSTRAP_ADMIN_ENABLED=false
# BOOTSTRAP_ADMIN_EMAIL=admin@yourcompany.com
# BOOTSTRAP_ADMIN_PASSWORD=
