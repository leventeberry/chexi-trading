# Copy to docker/.env and customize. Used by `make docker-up` when present (optional).
# Compose loads this file for variable substitution; `docker/docker-compose.yml` passes the same
# names through `chexi-api.environment` so values reach the API process (see that file for the list).
#
# Stack: docker-compose.yml + docker-compose.dev.yml (see README and docs/DOCKER.md).

# =============================================================================
# Hardened baseline ONLY (make docker-up-baseline — single compose file, no dev overlay)
# =============================================================================
# The baseline requires APP_ENV and DB_SSLMODE with no insecure compose defaults.
# Uncomment and set for production-like runs (example values — use your real policy):
# APP_ENV=production
# DB_SSLMODE=verify-full
# Also set POSTGRES_*, DB_*, JWT_SECRET (and other secrets) explicitly — no dev overlay defaults.

# =============================================================================
# Typical local dev (make docker-up / docker-all: baseline + docker-compose.dev.yml)
# =============================================================================

# --- Postgres (must match chexi-api DB_* when using the API container) ---
POSTGRES_USER=chexi_dev
POSTGRES_PASSWORD=change_this_local_postgres_password
POSTGRES_DB=chexi

# Publish DB only on loopback by default (optional overrides)
# POSTGRES_PUBLISH_HOST=127.0.0.1
# POSTGRES_PUBLISH_PORT=5432

# --- API container database client ---
DB_USER=chexi_dev
DB_PASS=change_this_local_postgres_password
DB_HOST=chexi-db
DB_PORT=5432
DB_NAME=chexi
DB_SSLMODE=disable

# JWT (use a long random value; never use demo secrets outside local dev)
JWT_SECRET=replace-with-long-random-secret-at-least-32-chars

PORT=8080
APP_ENV=development

# --- Redis ---
REDIS_ENABLED=true
REDIS_HOST=chexi-redis
REDIS_PORT=6379
REDIS_PASSWORD=
# REDIS_PUBLISH_HOST=127.0.0.1
# REDIS_PUBLISH_PORT=6379

REDIS_TLS_ENABLED=false
REDIS_TLS_SERVER_NAME=
REDIS_TLS_CA_CERT=
REDIS_TLS_INSECURE_SKIP_VERIFY=false

# --- API publish binding (baseline + dev) ---
# API_PUBLISH_HOST=127.0.0.1
# API_PUBLISH_PORT=8080

# --- Admin tools (dev overlay only; change defaults on shared machines) ---
REDIS_COMMANDER_HTTP_USER=chexi
REDIS_COMMANDER_HTTP_PASSWORD=change_this_redis_commander_password
# REDIS_COMMANDER_PORT=8081

PGADMIN_DEFAULT_EMAIL=pgadmin-dev@example.com
PGADMIN_DEFAULT_PASSWORD=change_this_pgadmin_password
# PGADMIN_PUBLISH_PORT=5050

# --- Logging & HTTP server (optional; see config.Load / logger) ---
# LOG_LEVEL=info
# HTTP_READ_HEADER_TIMEOUT_SEC=5
# HTTP_READ_TIMEOUT_SEC=30
# HTTP_WRITE_TIMEOUT_SEC=30
# HTTP_IDLE_TIMEOUT_SEC=120

# --- OpenAPI / Swagger (optional) ---
# SWAGGER_HOST=localhost:8080
# SWAGGER_ENABLED=true

# --- JWT lifetimes (optional) ---
# JWT_EXPIRATION_DAYS=1
# JWT_ACCESS_TOKEN_MINUTES=15
# JWT_REFRESH_EXPIRATION_HOURS=720

# --- Rate limiting (optional) ---
# RATE_LIMIT_REQUESTS_PER_MINUTE=60
# RATE_LIMIT_BURST_SIZE=10
# RATE_LIMIT_REDIS_FAILURE_MODE=   # fail_closed | local_fallback | fail_open (see root .env.example)

# --- HTTP security headers (optional; see README Middleware) ---
# SECURITY_HEADERS_ENABLED=true
# HSTS_ENABLED=false
# HSTS_MAX_AGE_SECONDS=31536000
# HSTS_INCLUDE_SUBDOMAINS=false

# --- Login/register JSON shape (optional; unset = false) ---
AUTH_RESPONSE_INCLUDE_API_KEY=false
AUTH_RESPONSE_INCLUDE_USER=false

# --- HTTP audit → Postgres (optional; high volume when enabled) ---
# AUDIT_HTTP_ENABLED=true
# AUDIT_HTTP_MUTATING_ONLY=true

# --- Admin event telemetry rate limits (optional) ---
# EVENT_TELEMETRY_RATE_LIMIT_RPM=120
# EVENT_TELEMETRY_BURST_SIZE=30

# --- Schema: GORM AutoMigrate vs versioned SQL (optional) ---
# USE_VERSIONED_MIGRATIONS=false
# In the API container, migrations are under /app/migrations (default relative dir "migrations" also works).
# MIGRATIONS_DIR=migrations

# --- Background job queue (optional; see docs/QUEUE.md) ---
# QUEUE_ENABLED=true
# QUEUE_ASYNC_ENABLED=true
# JOB_QUEUE_ENABLED=
# JOB_WORKER_ENABLED=true
# JOB_MAX_ATTEMPTS=
# JOB_RETRY_DELAY_SECONDS=
# QUEUE_WORKERS=2
# QUEUE_POLL_INTERVAL_MS=500
# QUEUE_MAX_ATTEMPTS=5
# QUEUE_INITIAL_BACKOFF_MS=1000
# QUEUE_MAX_BACKOFF_MS=300000
# QUEUE_SHUTDOWN_TIMEOUT_SEC=30
# QUEUE_DEAD_LETTER_MAX_CAP=10000

# --- MFA / TOTP (32-byte key, base64 or hex; see config) ---
# docker-compose.dev.yml supplies a dev-only default for MFA_ENCRYPTION_KEY when unset.
# MFA_ENCRYPTION_KEY=your-32-byte-key-base64-or-hex
# MFA_CHALLENGE_TTL_MINUTES=5
# MFA_RECOVERY_CODE_COUNT=8
# MFA_TOTP_ISSUER=chexi-trading

# --- Organization webhooks (same 32-byte encoding as MFA) ---
# WEBHOOK_ENCRYPTION_KEY=your-32-byte-key-base64-or-hex

# --- OAuth Google / GitHub (optional; requires OAUTH_REDIRECT_BASE_URL when any provider enabled) ---
# OAUTH_GOOGLE_ENABLED=false
# OAUTH_GITHUB_ENABLED=false
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=
# OAUTH_GITHUB_CLIENT_ID=
# OAUTH_GITHUB_CLIENT_SECRET=
# OAUTH_REDIRECT_BASE_URL=http://localhost:8080
# OAUTH_STATE_TTL_MINUTES=10
# OAUTH_EXCHANGE_TTL_MINUTES=10

# --- Email verification / password reset / org invites (optional) ---
# Defaults differ by APP_ENV; compose passes these into the API when set in docker/.env.
# EMAIL_ENABLED=true
# EMAIL_PROVIDER=log
# EMAIL_FROM=noreply@localhost
# APP_PUBLIC_URL=http://localhost:8080
# EMAIL_VERIFICATION_TTL_HOURS=48
# EMAIL_PASSWORD_RESET_TTL_HOURS=1
# ORG_INVITATION_TTL_HOURS=168
# EMAIL_RESEND_MIN_INTERVAL_SECONDS=60
# RESEND_API_KEY=re_
# Optional (development/test only — ignored in staging/production): send every transactional email to one inbox
# EMAIL_REDIRECT_ALL_TO=you@gmail.com

# --- Optional one-time first admin (startup). Remove after first successful deploy. ---
# BOOTSTRAP_ADMIN_ENABLED=false
# BOOTSTRAP_ADMIN_EMAIL=admin@yourcompany.com
# BOOTSTRAP_ADMIN_PASSWORD=use-a-strong-unique-secret-not-this-one
