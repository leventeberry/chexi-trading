# chexi-trading root environment template
#
# Copy this file to `.env` in the repository root. Root Makefile targets and
# Docker Compose use this file as the local source of truth.

# =============================================================================
# Local application environment
# =============================================================================
APP_ENV=development
PORT=8080
APP_PUBLIC_URL=http://localhost:8080

# =============================================================================
# PostgreSQL
# =============================================================================
# For Docker: POSTGRES_PASSWORD (db init) and DB_PASS (API) must match. The dev
# overlay syncs them when only one is set. If you change passwords after the DB
# volume exists, run `make docker-down-volumes` or update Postgres manually.
# Host-run API uses DB_HOST=localhost. Docker Compose maps the API container to
# the `chexi-db` service with DOCKER_DB_HOST below.
POSTGRES_USER=chexi_dev
POSTGRES_PASSWORD=change_this_local_postgres_password
POSTGRES_DB=chexi
DB_USER=chexi_dev
DB_PASS=change_this_local_postgres_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=chexi
DB_SSLMODE=disable
DOCKER_DB_HOST=chexi-db

# Publish DB only on loopback by default.
# POSTGRES_PUBLISH_HOST=127.0.0.1
# POSTGRES_PUBLISH_PORT=5432

# =============================================================================
# Redis
# =============================================================================
# Host-run API uses REDIS_HOST=localhost. Docker Compose maps the API container
# to the `chexi-redis` service with DOCKER_REDIS_HOST below.
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS_ENABLED=false
REDIS_TLS_SERVER_NAME=
REDIS_TLS_CA_CERT=
REDIS_TLS_INSECURE_SKIP_VERIFY=false
DOCKER_REDIS_HOST=chexi-redis

# REDIS_PUBLISH_HOST=127.0.0.1
# REDIS_PUBLISH_PORT=6379

# =============================================================================
# API container publishing
# =============================================================================
# Docker Compose project name. Defaults to `chexi-trading`; override only for parallel local stacks.
# COMPOSE_PROJECT_NAME=chexi-trading
# API_PUBLISH_HOST=127.0.0.1
# API_PUBLISH_PORT=8080

# =============================================================================
# Auth and security
# =============================================================================
JWT_SECRET=replace-with-long-random-secret-at-least-32-chars
# MFA_ENCRYPTION_KEY=your-32-byte-key-base64-or-hex
# WEBHOOK_ENCRYPTION_KEY=your-32-byte-key-base64-or-hex
# PROVIDER_CREDENTIAL_ENCRYPTION_KEY=your-32-byte-key-base64-or-hex

# Login/register JSON shape (optional; unset = false)
AUTH_RESPONSE_INCLUDE_API_KEY=false
AUTH_RESPONSE_INCLUDE_USER=false

# JWT lifetimes (optional)
# JWT_EXPIRATION_DAYS=1
# JWT_ACCESS_TOKEN_MINUTES=15
# JWT_REFRESH_EXPIRATION_HOURS=720

# HTTP security headers (optional)
# SECURITY_HEADERS_ENABLED=true
# HSTS_ENABLED=false
# HSTS_MAX_AGE_SECONDS=31536000
# HSTS_INCLUDE_SUBDOMAINS=false

# =============================================================================
# Rate limiting and telemetry
# =============================================================================
# RATE_LIMIT_REQUESTS_PER_MINUTE=60
# RATE_LIMIT_BURST_SIZE=10
# RATE_LIMIT_REDIS_FAILURE_MODE=local_fallback
# AUDIT_HTTP_ENABLED=true
# AUDIT_HTTP_MUTATING_ONLY=true
# EVENT_TELEMETRY_RATE_LIMIT_RPM=120
# EVENT_TELEMETRY_BURST_SIZE=30

# =============================================================================
# Migrations and queues
# =============================================================================
# USE_VERSIONED_MIGRATIONS=false
# MIGRATIONS_DIR=migrations
# QUEUE_ENABLED=true
# QUEUE_ASYNC_ENABLED=true
# JOB_QUEUE_ENABLED=
# JOB_WORKER_ENABLED=true
# JOB_MAX_ATTEMPTS=
# JOB_RETRY_DELAY_SECONDS=
# QUEUE_WORKERS=2
# QUEUE_POLL_INTERVAL_MS=500
# QUEUE_MAX_ATTEMPTS=5
# QUEUE_INITIAL_BACKOFF_MS=1000
# QUEUE_MAX_BACKOFF_MS=300000
# QUEUE_SHUTDOWN_TIMEOUT_SEC=30
# QUEUE_DEAD_LETTER_MAX_CAP=10000

# =============================================================================
# OAuth and email
# =============================================================================
# OAUTH_GOOGLE_ENABLED=false
# OAUTH_GITHUB_ENABLED=false
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=
# OAUTH_GITHUB_CLIENT_ID=
# OAUTH_GITHUB_CLIENT_SECRET=
# OAUTH_REDIRECT_BASE_URL=http://localhost:8080
# OAUTH_STATE_TTL_MINUTES=10
# OAUTH_EXCHANGE_TTL_MINUTES=10

# EMAIL_ENABLED=true
# EMAIL_DRIVER=log
# EMAIL_PROVIDER=log # deprecated alias; EMAIL_DRIVER wins when both are set
# EMAIL_LOG_INCLUDE_BODY=false # unsafe dev/test-only opt-in; forbidden in staging/production
# EMAIL_FROM=noreply@localhost
# EMAIL_VERIFICATION_TTL_HOURS=48
# EMAIL_PASSWORD_RESET_TTL_HOURS=1
# ORG_INVITATION_TTL_HOURS=168
# EMAIL_RESEND_MIN_INTERVAL_SECONDS=60
# RESEND_API_KEY= # only required when intentionally setting EMAIL_DRIVER=resend
# EMAIL_REDIRECT_ALL_TO=

# =============================================================================
# Dev-only admin tools
# =============================================================================
REDIS_COMMANDER_HTTP_USER=chexi
REDIS_COMMANDER_HTTP_PASSWORD=change_this_redis_commander_password
# REDIS_COMMANDER_PORT=8081

PGADMIN_DEFAULT_EMAIL=pgadmin-dev@example.com
PGADMIN_DEFAULT_PASSWORD=change_this_pgadmin_password
# PGADMIN_PUBLISH_PORT=5050

# =============================================================================
# Optional one-time first admin
# =============================================================================
# BOOTSTRAP_ADMIN_ENABLED=false
# BOOTSTRAP_ADMIN_EMAIL=admin@yourcompany.com
# BOOTSTRAP_ADMIN_PASSWORD=use-a-strong-unique-secret-not-this-one
